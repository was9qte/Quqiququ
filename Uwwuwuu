using System;

class ErrorEventArgs : EventArgs
{
    public string ИмяСвойства { get; set; }
    public string ТекстОшибки { get; set; }
    public DateTime ДатаВозникновенияОшибки { get; set; }

    public ErrorEventArgs(string имя, string текст, DateTime дата)
    {
        ИмяСвойства = имя;
        ТекстОшибки = текст;
        ДатаВозникновенияОшибки = дата;
    }
}







public string Login
{
    get { return login; }
    set
    {
        if (login != value && !string.IsNullOrEmpty(value))
        {
            login = value;
            OnPropertyChanged("Login");
        }
        else if (string.IsNullOrEmpty(value))
        {
            ErrorOccurred?.Invoke(this,
                new ErrorEventArgs("логин",
                "Логин не может быть пустым",
                DateTime.Now));
        }
    }
}









public string Password
{
    get { return password; }
    set
    {
        if (password != value && value.Length >= 8)
        {
            password = value;
            OnPropertyChanged("Password");
        }
        else if (value.Length < 8)
        {
            ErrorOccurred?.Invoke(this,
                new ErrorEventArgs("пароль",
                "Пароль должен быть не меньше 8 символов",
                DateTime.Now));
        }
    }
}







User user = new User();

user.PropertyChanged += User_PropertyChanged;
user.ErrorOccurred += User_ErrorOccurred;

user.Login = "";
user.Password = "123";

Console.ReadLine();









static void User_ErrorOccurred(object sender, ErrorEventArgs e)
{
    User u = (User)sender;

    Console.WriteLine($"{e.ДатаВозникновенияОшибки}: у пользователя {u.Login} не изменено {e.ИмяСвойства}");
    Console.WriteLine("Ошибка: " + e.ТекстОшибки);
}
